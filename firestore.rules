rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isWarden() {
      return request.auth != null &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'warden';
    }

    function isHeadWarden() {
      return request.auth != null &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'head-warden';
    }

    function isMessManager() {
      return request.auth != null &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'mess-manager';
    }

    // ── Students ─────────────────────────────────────────────
    match /students/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isWarden() || isHeadWarden() || isMessManager());
      allow write: if request.auth != null && (request.auth.uid == uid || isHeadWarden());
    }

    // ── Registration Activity ─────────────────────────────────
    match /registrationActivity/{actId} {
      allow read:   if request.auth != null && (isWarden() || isHeadWarden());
      allow create: if request.auth != null && (isWarden() || isHeadWarden());
    }

    // ── Complaints ────────────────────────────────────────────
    match /complaints/{complaintId} {
      allow read:   if request.auth != null &&
                       (resource.data.studentId == request.auth.uid || isWarden());
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                       (resource.data.studentId == request.auth.uid || isWarden());
    }

    // ── Notifications ─────────────────────────────────────────
    match /notifications/{notifId} {
      // Students: read/update their own. Wardens: write (send) to any.
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ── Transactions ──────────────────────────────────────────
    match /transactions/{txId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
      // No updates/deletes — transactions are immutable
    }

    // ── Mess Reductions ───────────────────────────────────────
    match /messReductions/{reqId} {
      allow read:   if request.auth != null &&
                       (resource.data.uid == request.auth.uid || isWarden() || isMessManager());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (isWarden() || isMessManager());
    }

    // ── Broadcasts ────────────────────────────────────────────
    match /broadcasts/{broadcastId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && isWarden();
    }

    // ── Meal Schedules ──────────────────────────────────────
    match /mealSchedules/{mealId} {
      allow read:   if request.auth != null; // All authenticated users can view meals
      allow create: if request.auth != null && isMessManager();
      allow update: if request.auth != null && isMessManager();
      allow delete: if request.auth != null && isMessManager();
    }

    // ── Meetings ──────────────────────────────────────────────
    match /meetings/{meetingId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null; // Students can request meetings
      allow update: if request.auth != null && (isWarden() || isHeadWarden()); // Only wardens/head-wardens approve
    }

    // ── Gender-specific hostels (optional rule for future filtering)
    // This allows querying by gender if you add it to documents
    match /hostels/{hostelId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && isHeadWarden();
    }
  }
}
